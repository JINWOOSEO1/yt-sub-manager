# Google OAuth2 credentials (from Google Cloud Console)
YSM_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
YSM_GOOGLE_CLIENT_SECRET=your-google-client-secret

# JWT secret (generate a random string for production)
YSM_JWT_SECRET_KEY=change-me-to-a-random-string

# WebSub callback URL (must be publicly accessible)
YSM_WEBSUB_CALLBACK_URL=https://your-domain.com/api/v1/websub/callback
YSM_WEBSUB_SECRET=change-me-websub-secret

# Firebase (optional, for push notifications)
YSM_FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json

# Scheduler settings
YSM_POLLING_INTERVAL_MINUTES=15
YSM_CLEANUP_HOUR=3
